# Copy this file to .env for local runs. Do not commit .env.
OPENAI_API_KEY=your-openai-or-udacity-provider-key

# Optional: set this for OpenAI-compatible providers. Leave blank for OpenAI.
OPENAI_BASE_URL=

# Optional model overrides.
CHAT_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-3-small
RAGAS_LLM_MODEL=gpt-3.5-turbo
RAGAS_EMBEDDING_MODEL=text-embedding-3-small
